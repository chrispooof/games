# Copy this file to .env and fill in values for your environment
NODE_ENV=development
PORT=3001
UI_ORIGIN=http://localhost:5173

# Local dev: point to DynamoDB Local (docker compose)
# Production: leave unset to use real AWS DynamoDB
DYNAMODB_ENDPOINT=http://localhost:8000

DYNAMODB_TABLE=CardGames
AWS_REGION=us-east-1

# Local dev only — DynamoDB Local accepts any credentials
# Production: use real IAM credentials or instance role (leave unset)
AWS_ACCESS_KEY_ID=local
AWS_SECRET_ACCESS_KEY=local
