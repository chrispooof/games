    "dotenv": "^16.4.7",
    "dynamodb-toolbox": "^2.8.0",
    "fastify": "^5.0.0",
    "socket.io": "^4.8.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22",
    "prettier": "^3.8.1",
    "tsx": "^4.19.0",
    "typescript": "^5.9.0",
    "vitest": "^4.1.0"
