{
  "name": "games-monorepo",
  "private": true,
  "workspaces": ["ui", "api"],
  "scripts": {
    "prepare": "husky",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "db:setup": "npm run db:setup -w api",
    "dev": "npm run docker:up && npm run db:setup && concurrently -n api,ui -c blue.bold,green.bold \"npm run dev -w api\" \"npm run dev -w ui\"",
    "build": "nx run-many -t build",
    "test": "nx run-many -t test",
    "typecheck": "nx run-many -t typecheck",
    "lint": "nx run-many -t lint",
    "format": "nx run-many -t format"
  },
  "devDependencies": {
    "concurrently": "^9.0.0",
    "husky": "^9.1.7",
    "nx": "latest",
    "prettier": "^3.8.1"
  }
}
