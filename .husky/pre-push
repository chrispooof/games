#!/bin/sh
# Get changed files between remote tracking branch and HEAD
REMOTE=$(git rev-parse --abbrev-ref --symbolic-full-name @{u} 2>/dev/null)

if [ -n "$REMOTE" ]; then
  REMOTE_SHA=$(git rev-parse "$REMOTE" 2>/dev/null)
  CHANGED=$(git diff --name-only "$REMOTE_SHA" HEAD 2>/dev/null)
else
  CHANGED=$(git diff --name-only HEAD~1 HEAD 2>/dev/null)
fi

if [ -z "$CHANGED" ]; then
  echo "No changed files, skipping tests"
  exit 0
fi

# Filter changed files by workspace and strip workspace prefix for vitest
UI_CHANGED=$(echo "$CHANGED" | grep '^ui/' | sed 's|^ui/||' | tr '\n' ' ')
API_CHANGED=$(echo "$CHANGED" | grep '^api/' | sed 's|^api/||' | tr '\n' ' ')

if [ -z "$UI_CHANGED" ] && [ -z "$API_CHANGED" ]; then
  echo "No ui/api files changed, skipping tests"
  exit 0
fi

if [ -n "$UI_CHANGED" ]; then
  (cd ui && npx vitest related --passWithNoTests $UI_CHANGED) || exit 1
fi

if [ -n "$API_CHANGED" ]; then
  (cd api && npx vitest related --passWithNoTests $API_CHANGED) || exit 1
fi
